{
  "name": "miany-soul",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript 全栈基础框架",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @miany-soul/backend dev\" \"pnpm --filter @miany-soul/frontend dev\"",
    "build": "pnpm --filter @miany-soul/shared build && pnpm --filter @miany-soul/backend build && pnpm --filter @miany-soul/frontend build",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "prepare": "husky install",
    "db:push": "pnpm --filter @miany-soul/backend db:push",
    "db:migrate": "pnpm --filter @miany-soul/backend db:migrate",
    "db:seed": "pnpm --filter @miany-soul/backend db:seed",
    "db:studio": "pnpm --filter @miany-soul/backend db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.27.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
