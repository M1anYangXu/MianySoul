generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表 - 预留基础字段，支持软删除
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("user") // admin, user
  avatar    String?
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([email])
  @@index([role])
}

// 角色权限表 - 预留扩展
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String  @default("[]") // JSON 数组存储权限列表
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}