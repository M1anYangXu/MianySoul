generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表 - 预留基础字段，支持软删除
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("user") // admin, user
  avatar    String?
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([email])
  @@index([role])
}

// 角色权限表 - 预留扩展
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String  @default("[]") // JSON 数组存储权限列表
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 系统配置表
model Config {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Scene {
  id          String   @id @default(uuid())
  sceneId     String   @unique
  name        String
  icon        String
  description String?
  image       String
  audioUrl    String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sceneId])
  @@index([isActive])
  @@index([sortOrder])
}

// 回忆录 - 分类
model MemoirCategory {
  id          String   @id @default(uuid())
  name        String   // 如：小学、初中、大学、工作
  icon        String   @default("📖")
  description String?
  sortOrder   Int      @default(0)
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     MemoirEntry[]

  @@index([userId])
  @@index([sortOrder])
}

// 回忆录 - 条目
model MemoirEntry {
  id          String   @id @default(uuid())
  categoryId  String
  title       String
  content     String
  imageUrl    String?  // 关联图片地址（可选）
  eventDate   DateTime?  // 事件发生日期
  sortOrder   Int      @default(0)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    MemoirCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([eventDate])
}

// 梦境记录
model Dream {
  id          String   @id @default(uuid())
  userId      String
  content     String
  dreamDate   DateTime  // 梦境日期
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([dreamDate])
}

// 日记
model Diary {
  id          String   @id @default(uuid())
  userId      String
  content     String
  weather     String?  // 天气：sunny, cloudy, rainy, snowy, windy, foggy
  mood        String?  // 心情：happy, calm, anxious, sad, angry, excited
  imageUrl    String?  // 图片地址（可选）
  isOutside   Boolean? @default(false)  // 是否外出
  diaryDate   DateTime  // 日记日期
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([diaryDate])
}

// 图片分组
model ImageGroup {
  id          String   @id @default(uuid())
  name        String   // 分组名称
  description String?  // 分组描述
  icon        String   @default("📁")
  isDefault   Boolean  @default(false)  // 是否默认分组
  sortOrder   Int      @default(0)
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      Image[]

  @@index([userId])
  @@index([isDefault])
  @@index([sortOrder])
}

// 图片
model Image {
  id          String   @id @default(uuid())
  groupId     String?  // 所属分组，可为空表示未分组
  userId      String
  filename    String   // 原始文件名
  url         String   // 存储路径/URL
  size        Int      // 文件大小（字节）
  mimetype    String   // MIME类型
  width       Int?     // 图片宽度
  height      Int?     // 图片高度
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group       ImageGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupId])
}