generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String
  role      String    @default("user")
  avatar    String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([username])
  @@index([email])
  @@index([role])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Config {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Scene {
  id          String    @id @default(uuid())
  sceneId     String    @unique
  name        String
  icon        String
  description String?
  image       String
  audioUrl    String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sceneId])
  @@index([isActive])
  @@index([sortOrder])
}

model MemoirCategory {
  id          String        @id @default(uuid())
  name        String
  icon        String        @default("📖")
  description String?
  sortOrder   Int           @default(0)
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  entries     MemoirEntry[]

  @@index([userId])
  @@index([sortOrder])
}

model MemoirEntry {
  id         String         @id @default(uuid())
  categoryId String
  title      String
  content    String
  imageUrl   String?
  eventDate  DateTime?
  sortOrder  Int            @default(0)
  deletedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  category   MemoirCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([eventDate])
}

model Dream {
  id        String    @id @default(uuid())
  userId    String
  content   String
  dreamDate DateTime
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([dreamDate])
}

model Diary {
  id         String       @id @default(uuid())
  userId     String
  content    String
  weather    String?
  mood       String?
  isOutside  Boolean?     @default(false)
  diaryDate  DateTime
  deletedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  images     DiaryImage[]

  @@index([userId])
  @@index([diaryDate])
}

model DiaryImage {
  id        String    @id @default(uuid())
  diaryId   String
  imageUrl  String
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  diary     Diary     @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@index([diaryId])
  @@index([sortOrder])
}

model ImageGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  icon        String    @default("📁")
  isDefault   Boolean   @default(false)
  sortOrder   Int       @default(0)
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  images      Image[]

  @@index([userId])
  @@index([isDefault])
  @@index([sortOrder])
}

model Image {
  id        String      @id @default(uuid())
  groupId   String?
  userId    String
  filename  String
  url       String
  size      Int
  mimetype  String
  width     Int?
  height    Int?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  group     ImageGroup? @relation(fields: [groupId], references: [id])

  @@index([userId])
  @@index([groupId])
}

model VideoGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  icon        String    @default("📁")
  isDefault   Boolean   @default(false)
  sortOrder   Int       @default(0)
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  videos      Video[]

  @@index([userId])
  @@index([isDefault])
  @@index([sortOrder])
}

model Video {
  id        String      @id @default(uuid())
  groupId   String?
  userId    String
  filename  String
  url       String
  thumbnail String?
  size      Int
  mimetype  String
  duration  Int?
  width     Int?
  height    Int?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  group     VideoGroup? @relation(fields: [groupId], references: [id])

  @@index([userId])
  @@index([groupId])
}

model ArticleCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  deletedAt DateTime?
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
}

model ArticleTag {
  id        String               @id @default(uuid())
  name      String               @unique
  deletedAt DateTime?
  articles  ArticleTagRelation[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([name])
}

model ArticleTagRelation {
  id        String     @id @default(uuid())
  articleId String
  tagId     String
  createdAt DateTime   @default(now())
  tag       ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model Article {
  id         String               @id @default(uuid())
  title      String
  content    String
  excerpt    String?
  categoryId String?
  coverImage String?
  status     String               @default("draft")
  authorId   String
  viewCount  Int                  @default(0)
  likeCount  Int                  @default(0)
  deletedAt  DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  category   ArticleCategory?     @relation(fields: [categoryId], references: [id])
  tags       ArticleTagRelation[]

  @@index([title])
  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
}

model MusicLyric {
  id        String    @id @default(uuid())
  singer    String
  songName  String
  lyric     String
  coverImage String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([singer])
  @@index([songName])
  @@index([isActive])
  @@index([sortOrder])
}
